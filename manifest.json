{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "JSON Beautifier Pro",
  "version": "1.0.0",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "author": "JSON Tools Dev",
  "homepage_url": "https://github.com/json-beautifier-pro",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "format-json": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "__MSG_cmdFormatJson__"
    }
  },
  "offline_enabled": true
}